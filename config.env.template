# =============================================================================
# LeaseMiner Configuration
# =============================================================================
# Copy this file to config.env and fill in your values:
#   cp config.env.template config.env
#
# Then run the setup script:
#   ./setup.sh
# =============================================================================

# --- REQUIRED: Your Databricks workspace ---
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_PROFILE=                        # Databricks CLI profile name (optional, uses default if blank)

# --- REQUIRED: Unity Catalog configuration ---
DATABRICKS_CATALOG=                        # e.g., my_catalog
DATABRICKS_SCHEMA=lease_management         # Schema name (default: lease_management)
DATABRICKS_VOLUME=raw_lease_docs           # Volume name (default: raw_lease_docs)

# --- REQUIRED: SQL Warehouse ---
DATABRICKS_WAREHOUSE_ID=                   # Your serverless SQL warehouse ID

# --- REQUIRED: Serving endpoint for Claude ---
SERVING_ENDPOINT=databricks-claude-sonnet-4-5

# --- OPTIONAL: App name ---
APP_NAME=lease-extraction

# --- AUTO-POPULATED by setup.sh (leave blank) ---
INGEST_JOB_ID=
PIPELINE_JOB_ID=
NOTEBOOK_PATH=
